#!/usr/bin/env bash
set -euo pipefail

echo "==> pre-commit: cargo fmt --check"
cargo fmt --check || { echo "Run 'cargo fmt' to fix formatting."; exit 1; }

echo "==> pre-commit: cargo clippy"
cargo clippy -- -D warnings || { echo "Fix clippy warnings before committing."; exit 1; }

echo "==> pre-commit: cargo deny check"
if command -v cargo-deny >/dev/null 2>&1; then
    cargo deny check advisories bans sources || { echo "Fix cargo-deny issues."; exit 1; }
else
    echo "cargo-deny not installed, skipping (install: cargo install cargo-deny)"
fi

echo "==> pre-commit: cargo test"
cargo test --quiet || { echo "Tests failed."; exit 1; }
